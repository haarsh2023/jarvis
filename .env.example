# Copy this file to .env and fill in your real keys.
# NEVER commit the real .env file to GitHub.

# Get from https://console.groq.com  (free tier)
GROQ_API_KEY=your_groq_key_here

# Get from https://tavily.com  (free tier, ~1000 searches/month)
TAVILY_API_KEY=your_tavily_key_here

# Port Render will inject this automatically, but useful for local dev
PORT=5000

# Comma-separated list of allowed frontend origins (your Netlify/Vercel URL + localhost for dev)
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-site.netlify.app
